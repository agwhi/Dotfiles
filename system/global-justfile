# Global Justfile - Available system-wide for all projects
js_toolchain := "$HOME/.dotfiles/scripts/js_toolchain.sh"

# Run quality checks (security + formatting)
quality-check:
    ripsecrets --strict-ignore .
    gitleaks detect --source . --verbose
    editorconfig-checker
    dotenv-linter
    echo "✅ Quality checks complete"

# Run security scans only
security-scan:
    ripsecrets --strict-ignore .
    gitleaks detect --source . --verbose
    echo "✅ Security scan complete"

# Lint code with Biome (if biome.json exists)
lint:
    sh -c 'if [ -f "biome.json" ]; then {{js_toolchain}} biome lint --files-ignore-unknown=true .; else echo "⚠️  No biome.json found. Run biome init to create one."; fi'

# Format code with Biome (if biome.json exists)
format:
    sh -c 'if [ -f "biome.json" ]; then {{js_toolchain}} biome format .; else echo "⚠️  No biome.json found. Run biome init to create one."; fi'

# Lint markdown files (if markdownlint is available)
docs-lint:
    sh -c 'if {{js_toolchain}} markdownlint --version >/dev/null 2>&1; then {{js_toolchain}} markdownlint *.md; else echo "⚠️  markdownlint not installed. Run: dotfile setup-node"; fi'

# Fix formatting issues
fix-formatting:
    dotenv-linter fix
    echo "✅ Formatting fixes applied"

# Upgrade all packages and tools
upgrade:
    topgrade

# Setup Node.js environment (if fnm is available)
setup-node:
    sh -c 'if ! command -v fnm >/dev/null 2>&1; then echo "⚠️  fnm not found. Install with: brew install fnm"; exit 1; fi'
    fnm install --lts
    fnm use lts-latest
    fnm default lts-latest
    {{js_toolchain}} corepack enable
    {{js_toolchain}} corepack prepare pnpm@latest --activate
    echo "✅ Node.js LTS and pnpm ready"

# Setup .NET environment
setup-dotnet:
    dotnet tool install -g Amazon.Lambda.Tools || echo "Amazon.Lambda.Tools already installed"
    dotnet tool install -g Amazon.Lambda.TestTool-8.0 || echo "Amazon.Lambda.TestTool-8.0 already installed"
    echo "✅ .NET Lambda tools installed"

# Configure AWS CLI
setup-aws:
    aws configure sso
    echo "✅ AWS CLI configured"

# Initialize Biome in current project (if not already exists)
init-biome:
    sh -c 'if [ -f "biome.json" ]; then echo "⚠️  biome.json already exists"; else {{js_toolchain}} biome init; echo "✅ Biome initialized. Edit biome.json to customize settings."; fi'



# --- Network Security & Privacy Commands ---

# Start DNS encryption service
dns-secure-start:
    brew services start dnscrypt-proxy
    echo "✅ DNS encryption started (dnscrypt-proxy)"

# Stop DNS encryption service
dns-secure-stop:
    brew services stop dnscrypt-proxy
    echo "✅ DNS encryption stopped"

# Connect to VPN
vpn-secure-on:
    nordvpn connect
    echo "✅ VPN connected"

# Disconnect VPN
vpn-secure-off:
    nordvpn disconnect
    echo "✅ VPN disconnected"

# Start both VPN and DNS encryption (use on untrusted networks)
secure-mode-on:
    # Use this on untrusted networks (cafés, airports, hotels, conferences)
    just dns-secure-start
    sleep 2
    just vpn-secure-on
    echo "🛡️  Secure mode enabled: DNS encryption + VPN active"
    echo "💡 Use 'just secure-mode-off' to disable"

# Stop both VPN and DNS encryption
secure-mode-off:
    just vpn-secure-off
    sleep 2
    just dns-secure-stop
    echo "✅ Secure mode disabled"

# Test for DNS leaks
dns-leak-test:
    open https://dnsleaktest.com
    echo "🌐 DNS leak test opened in browser"
    echo "💡 Check that your DNS shows encrypted resolvers (not ISP)"

# Backup LuLu firewall rules
lulu-backup:
    sh -c 'if [ -f "$HOME/.dotfiles/scripts/lulu_backup.sh" ]; then $HOME/.dotfiles/scripts/lulu_backup.sh backup; else echo "⚠️  LuLu backup script not found. Run dotfiles setup first."; fi'

# Restore LuLu firewall rules
lulu-restore:
    sh -c 'if [ -f "$HOME/.dotfiles/scripts/lulu_backup.sh" ]; then $HOME/.dotfiles/scripts/lulu_backup.sh restore; else echo "⚠️  LuLu backup script not found. Run dotfiles setup first."; fi'

# List LuLu firewall rule backups
lulu-list:
    sh -c 'if [ -f "$HOME/.dotfiles/scripts/lulu_backup.sh" ]; then $HOME/.dotfiles/scripts/lulu_backup.sh list; else echo "⚠️  LuLu backup script not found. Run dotfiles setup first."; fi'

# Show available commands
help:
    @just --list
